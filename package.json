{
	"name": "n8n-nodes-vrchat",
	"version": "1.0.0",
	"description": "n8n community node for interacting with the VRChat API.",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "mmr",
